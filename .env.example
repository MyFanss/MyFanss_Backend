# ─── Server ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=myfans

# ─── JWT ─────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ─── Rate Limiting ───────────────────────────────────
# Set to "false" to disable all rate limiting (not recommended for production)
THROTTLE_ENABLED=true

# Auth tier (login, signup, refresh — strictest)
THROTTLE_AUTH_TTL=60
THROTTLE_AUTH_LIMIT=5

# Short tier (lightweight frequent operations)
THROTTLE_SHORT_TTL=10
THROTTLE_SHORT_LIMIT=30

# Medium tier (general API — default)
THROTTLE_MEDIUM_TTL=60
THROTTLE_MEDIUM_LIMIT=120

# Long tier (read-heavy, low-risk)
THROTTLE_LONG_TTL=3600
THROTTLE_LONG_LIMIT=3600

# Optional Redis-backed store (removes dependency on in-memory counters)
# If unset, the in-memory ThrottlerStorage is used (not recommended for multi-replica deployments)
# REDIS_URL=redis://localhost:6379

# Proxy trust — set "true" when behind a reverse proxy so X-Forwarded-For is honored
TRUST_PROXY=false

# ─── Avatar / File Uploads ────────────────────────────
# Storage driver: "local" (default) or "s3"
STORAGE_DRIVER=local

# Root directory for locally stored uploads (relative to project root)
UPLOAD_DIR=./uploads

# Public base URL used to build avatarUrl in API responses
# For local dev this should match your server's host + port
PUBLIC_BASE_URL=http://localhost:3000
